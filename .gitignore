backend/data/config.yaml
backend/data/*.yaml
# プロジェクト別の手動ラベル（精度測定用のユーザーデータ）
backend/data/labels/
# 作業状態ファイル（設定一式・API キーを含みうる）
*.ymmemo
# 環境変数・認証情報
.env
.env.*
*.pem
*.key
secrets.*

# ===== ダウンロード済みモデル（大容量） =====
backend/models/*
!backend/models/.gitkeep

