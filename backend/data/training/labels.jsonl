{"text": "皆さんこんにちは、IAです。", "character": "IA_時雨Jun様", "emotion": "joy", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "OИEでーす。", "character": "OИE_時雨Jun様", "emotion": "happiness", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "えっ？", "character": "OИE_時雨Jun様", "emotion": "surprise", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "はい、気を取り直して…", "character": "OИE_時雨Jun様", "emotion": "exasperation", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "女の子がかわいいよ。", "character": "IA_時雨Jun様", "emotion": "joy", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "話が全然入ってこなかったけど…。", "character": "OИE_時雨Jun様", "emotion": "exasperation", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "ねぇ全部見た目の印象じゃなかった？", "character": "OИE_時雨Jun様", "emotion": "exasperation", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "わっ。", "character": "IA_時雨Jun様", "emotion": "surprise", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "えーっ。", "character": "IA_時雨Jun様", "emotion": "surprise", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "あ、倒しちゃった…。", "character": "IA_時雨Jun様", "emotion": "sadness", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "あっ。", "character": "IA_時雨Jun様", "emotion": "surprise", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "かわいいー。", "character": "IA_時雨Jun様", "emotion": "joy", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "ありゃ？", "character": "IA_時雨Jun様", "emotion": "surprise", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "あーっ！", "character": "IA_時雨Jun様", "emotion": "surprise", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "はい、おっけーです！", "character": "IA_時雨Jun様", "emotion": "happiness", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "がんばります！", "character": "IA_時雨Jun様", "emotion": "happiness", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "ふみゅ！", "character": "IA_時雨Jun様", "emotion": "sadness", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "にゅん！", "character": "IA_時雨Jun様", "emotion": "happiness", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "えいや！", "character": "IA_時雨Jun様", "emotion": "happiness", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "わー、全然でしたねぇ…。", "character": "IA_時雨Jun様", "emotion": "exasperation", "source_project": "Aruta.ymmp", "ts": 1780657042.3289983}
{"text": "かわいいですねぇ。", "character": "IA_時雨Jun様", "emotion": "joy", "source_project": "gogh.ymmp", "ts": 1780657164.6767137}
{"text": "さぁ…？", "character": "琴葉葵_時雨jun様", "emotion": "sadness", "source_project": "gogh.ymmp", "ts": 1780657164.6767137}
{"text": "それなんだよねぇ…。", "character": "琴葉葵_時雨jun様", "emotion": "sadness", "source_project": "gogh.ymmp", "ts": 1780657164.6767137}
{"text": "IAちゃん！？", "character": "琴葉葵_時雨jun様", "emotion": "surprise", "source_project": "gogh.ymmp", "ts": 1780657164.6767137}
{"text": "え、えっと！", "character": "琴葉葵_時雨jun様", "emotion": "surprise", "source_project": "gogh.ymmp", "ts": 1780657164.6767137}
{"text": "そうそう。", "character": "琴葉葵_時雨jun様", "emotion": null, "source_project": "gogh.ymmp", "ts": 1780657164.6767137}
{"text": "…………。", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "fear", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "まぁいいや。", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "exasperation", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "セキニンモンダイだぁ。", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "sadness", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "あらかわいいシスターさん。", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "embarrassment", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "どんな思いでも…ってことは、ラブレターのご依頼かなぁ！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "embarrassment", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "きゃー、初仕事はラブレターの代筆だー！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "embarrassment", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "えーと、はい。", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "exasperation", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "えっと、えっとぉ…。", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "fear", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "…おー……。", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "fear", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "あ゛ー…(絶望", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "fear", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "えーーーーーとぉ……。", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "fear", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "はいっ。(元気)", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "happiness", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "ただの女の敵。", "character": "琴葉葵_時雨jun様", "emotion": "disgust", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "女の敵だぁ！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "disgust", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "そぉい！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "happiness", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "いきすぎたぁ！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "surprise", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "しょんぼり", "character": "ヰ世界情緒_星界", "emotion": "sadness", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "もうどうにでもなぁれ！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "anger", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "んおお？", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "anger", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "あ、ぜんぜん違う！？", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "surprise", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "キタキタキター！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "joy", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "違うよ！？", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "surprise", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "あーーーーん！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "sadness", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "おわりだー！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "sadness", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "ここからどうするのぉーんもぉー！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "sadness", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "弱そう。", "character": "琴葉葵_時雨jun様", "emotion": "exasperation", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "えへっ♪", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "happiness", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "えっ、上手くいかなかったら私のせい？", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "fear", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "こう！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "anger", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "ひぇっ…。", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "fear", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "じつは気持ちを隠してたんだよ？って流れはどうかなぁ？", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "embarrassment", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "きゃー、甘酸っぱーい！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "embarrassment", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "なんか思った言葉がないんですけど？(焦り", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "fear", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "さぁ、トドメの一撃を！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "anger", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "ぱーぺき☆(完璧)でーす！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "joy", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "えーーー……？", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "disgust", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "えっ、あのっ、これでダメなんですか？", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "disgust", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "おっつかれさまでーしたっ！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "joy", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "ふふふっ。", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "embarrassment", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "なんか、エモいよね！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "joy", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "にゃあ゛あ゛あ゛あ゛っ！？", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "surprise", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "ううん？", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "happiness", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "おおん？", "character": "琴葉葵_時雨jun様", "emotion": "disgust", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780657925.9372106}
{"text": "こう！", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "anger", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780658235.230864}
{"text": "えっと、えっとぉ…。", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "fear", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780665727.2976692}
{"text": "フンフフーン♪", "character": "ヰ世界情緒_星界", "emotion": "embarrassment", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780665727.2976692}
{"text": "私なんにも悪いことしてませんよ！？", "character": "紲星あかり_時雨jun様 (ドット)", "emotion": "fear", "source_project": "代筆屋ワールドワード.ymmp", "ts": 1780665727.2976692}
{"text": "えへへ。", "character": "IA_時雨Jun様", "emotion": "embarrassment", "source_project": "MIO.ymmp", "ts": 1780666188.0749235}
{"text": "ね？", "character": "IA_時雨Jun様", "emotion": "embarrassment", "source_project": "MIO.ymmp", "ts": 1780666188.0749235}
{"text": "え、なになになに？", "character": "IA_時雨Jun様", "emotion": "surprise", "source_project": "MIO.ymmp", "ts": 1780666188.0749235}
{"text": "ひゃーい、暗い…。", "character": "IA_時雨Jun様", "emotion": "fear", "source_project": "MIO.ymmp", "ts": 1780666188.0749235}
{"text": "お、驚きませんからね。", "character": "IA_時雨Jun様", "emotion": "fear", "source_project": "MIO.ymmp", "ts": 1780666188.0749235}
{"text": "…じゃあしょうがないですね。", "character": "IA_時雨Jun様", "emotion": "sadness", "source_project": "MIO.ymmp", "ts": 1780666188.0749235}
{"text": "えーい！", "character": "IA_時雨Jun様", "emotion": "happiness", "source_project": "MIO.ymmp", "ts": 1780666188.0749235}
{"text": "ふみゅ！", "character": "IA_時雨Jun様", "emotion": "surprise", "source_project": "MIO.ymmp", "ts": 1780666188.0749235}
{"text": "ぴょーん！", "character": "IA_時雨Jun様", "emotion": "happiness", "source_project": "MIO.ymmp", "ts": 1780666188.0749235}
{"text": "楽しーい。", "character": "IA_時雨Jun様", "emotion": "happiness", "source_project": "MIO.ymmp", "ts": 1780666188.0749235}
{"text": "ぴょーん！", "character": "IA_時雨Jun様", "emotion": "joy", "source_project": "MIO.ymmp", "ts": 1780666188.0749235}
{"text": "うわ、ロボットが串刺しになってる…？", "character": "琴葉葵_時雨jun様", "emotion": "fear", "source_project": "MIO.ymmp", "ts": 1780666188.0749235}
{"text": "ひぇっ。", "character": "IA_時雨Jun様", "emotion": "fear", "source_project": "MIO.ymmp", "ts": 1780666188.0749235}
{"text": "うわっ。", "character": "琴葉葵_時雨jun様", "emotion": "surprise", "source_project": "MIO.ymmp", "ts": 1780666188.0749235}
{"text": "BGMも不安を煽りますねぇ…。", "character": "IA_時雨Jun様", "emotion": "disgust", "source_project": "MIO.ymmp", "ts": 1780666188.0749235}
{"text": "曲も豪華になっててテンションも上がっちゃいます。", "character": "IA_時雨Jun様", "emotion": "happiness", "source_project": "MIO.ymmp", "ts": 1780666188.0749235}
{"text": "なんかヤバそうな雰囲気してるなぁ…。", "character": "OИE_時雨Jun様", "emotion": "disgust", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "いや、うん、プレイしたら分かるんじゃないかな。", "character": "OИE_時雨Jun様", "emotion": "disgust", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "不安。", "character": "OИE_時雨Jun様", "emotion": "fear", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "どこに行けばいいの？", "character": "IA_時雨Jun様 (Af)", "emotion": "sadness", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "もう難しいよぉ。", "character": "IA_時雨Jun様 (Af)", "emotion": "sadness", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "…今の、IAは納得いかないのですけど？", "character": "IA_時雨Jun様 (Af)", "emotion": "disgust", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "わっとと…。", "character": "IA_時雨Jun様 (Af)", "emotion": "surprise", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "せ、せーふです。", "character": "IA_時雨Jun様 (Af)", "emotion": "embarrassment", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "…嫌な予感がしますねぇ…。", "character": "IA_時雨Jun様 (Af)", "emotion": "fear", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "ひゃわ！", "character": "IA_時雨Jun様 (Af)", "emotion": "surprise", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "あわわわわ。", "character": "IA_時雨Jun様 (Af)", "emotion": "surprise", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "怖い怖い。", "character": "IA_時雨Jun様 (Af)", "emotion": "fear", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "ですよねー…。", "character": "IA_時雨Jun様 (Af)", "emotion": "sadness", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "みゃー！", "character": "IA_時雨Jun様 (Af)", "emotion": "fear", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "おめでとー。", "character": "OИE_時雨Jun様", "emotion": "joy", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "あーーー…。", "character": "IA_時雨Jun様 (Af)", "emotion": "exasperation", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "ということで、IAの心はめためたにされちゃったのです…。", "character": "IA_時雨Jun様 (Af)", "emotion": "sadness", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "はぁい。", "character": "IA_時雨Jun様 (Af)", "emotion": "sadness", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "よろしくお願いしまーす。", "character": "OИE_時雨Jun様", "emotion": "happiness", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "それじゃ、ばいばーい。", "character": "IA_時雨Jun様 (Af)", "emotion": "joy", "source_project": "ググピザ.ymmp", "ts": 1780666512.07936}
{"text": "魔女っ子になりたーい！", "character": "琴葉茜_時雨jun様", "emotion": "joy", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "魔法ってなんでしたっけ…。", "character": "OИE_時雨Jun様", "emotion": "exasperation", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "ってどういうことや？", "character": "琴葉茜_時雨jun様", "emotion": "surprise", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "…カレーやなぁ。", "character": "琴葉茜_時雨jun様", "emotion": null, "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "カレーですねぇ。", "character": "OИE_時雨Jun様", "emotion": null, "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "魔女修行、ファンタジーらしくてええ響きやな！", "character": "琴葉茜_時雨jun様", "emotion": "joy", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "ほう、やっぱりホントなんか？", "character": "琴葉茜_時雨jun様", "emotion": "happiness", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "そうだよ！？", "character": "OИE_時雨Jun様", "emotion": "surprise", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "まんまと騙されたなぁ。", "character": "琴葉茜_時雨jun様", "emotion": "sadness", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "ってわけで、お外にゴーや！", "character": "琴葉茜_時雨jun様", "emotion": "happiness", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "夜の散歩ってなんかワクワクするよな。", "character": "琴葉茜_時雨jun様", "emotion": "joy", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "ふんぬらばっ！", "character": "琴葉茜_時雨jun様", "emotion": "anger", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "ちぇー。", "character": "琴葉茜_時雨jun様", "emotion": "sadness", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "序盤から熊はキツすぎない？", "character": "OИE_時雨Jun様", "emotion": "fear", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "茜ちゃんは図太いから…。", "character": "OИE_時雨Jun様", "emotion": "exasperation", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "うちらは親友やから問題ないな！", "character": "琴葉茜_時雨jun様", "emotion": "embarrassment", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "んもぅ。", "character": "OИE_時雨Jun様", "emotion": "embarrassment", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "かわいいー。", "character": "OИE_時雨Jun様", "emotion": "joy", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "えー。", "character": "琴葉茜_時雨jun様", "emotion": "disgust", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "メタいなぁ。", "character": "OИE_時雨Jun様", "emotion": "exasperation", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "今なんて？", "character": "OИE_時雨Jun様", "emotion": "exasperation", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "ほぉーん？", "character": "琴葉茜_時雨jun様", "emotion": "surprise", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "うへぇ。", "character": "琴葉茜_時雨jun様", "emotion": "sadness", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "限定レシピってなんか心躍るな！", "character": "琴葉茜_時雨jun様", "emotion": "joy", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "なんかぎこちなくない？", "character": "OИE_時雨Jun様", "emotion": "exasperation", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "どや！", "character": "琴葉茜_時雨jun様", "emotion": "joy", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "…そうか？", "character": "琴葉茜_時雨jun様", "emotion": "exasperation", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "そうかな…そうかも…。", "character": "琴葉茜_時雨jun様", "emotion": "exasperation", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "大自然なんてクソ食らえ！", "character": "琴葉茜_時雨jun様", "emotion": "anger", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "とうちゃーく！", "character": "OИE_時雨Jun様", "emotion": "joy", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "どうや、上手くなってきたで！", "character": "琴葉茜_時雨jun様", "emotion": "joy", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "わぁ、おいしそう！", "character": "OИE_時雨Jun様", "emotion": "embarrassment", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "うっ、まずい。", "character": "OИE_時雨Jun様", "emotion": "sadness", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "いけしゃあしゃあ。", "character": "OИE_時雨Jun様", "emotion": "exasperation", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
{"text": "わぁー…幻想的ー…。", "character": "OИE_時雨Jun様", "emotion": "happiness", "source_project": "Little Witch in the Woods.ymmp", "ts": 1780667085.8135488}
